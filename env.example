# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Authorized Telegram user IDs (comma-separated, get IDs from @userinfobot)
# Example: 123456789,987654321 for multiple users
TELEGRAM_USER_IDS=123456789,987654321

# Google Calendar API Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google Refresh Token (obtained after first OAuth flow)
# Run: python -m src.auth_setup to get this token
GOOGLE_REFRESH_TOKEN=

# Calendar ID to use (usually "primary" for your main calendar)
GOOGLE_CALENDAR_ID=primary

# Timezone for calendar events
TIMEZONE=Asia/Singapore

# Redis (used by docker-compose automatically). Override only if using an external Redis.
# With docker-compose, the bot uses redis://redis:6379/0 by default.
# REDIS_URL=redis://redis:6379/0

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/Disable calendar uploads (false = dry-run mode for testing OCR)
ENABLE_CALENDAR_UPLOAD=true

# Save cropped cell images to debug/ folder for debugging OCR
DEBUG_SAVE_CELLS=false

# Use only color detection for shifts, skip OCR entirely
# Useful if OCR is unreliable and you have good color mappings
COLOR_ONLY_MODE=false

# Delete all events in the month before uploading new ones
# WARNING: Destructive! Use only for development/testing
WIPE_CALENDAR_BEFORE_UPLOAD=false

# How often to check and send reminders (seconds). Default 300 (5 min). In dev, set to 30 or 60 to test quickly.
# REMINDER_JOB_INTERVAL_SECONDS=300

# How long before re-sending the same reminder if not acknowledged (seconds). Default 2700 (45 min). In dev, set to 30–60 to re-trigger soon.
# REMINDER_SENT_SLOT_TTL_SECONDS=2700
