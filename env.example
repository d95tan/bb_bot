# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Your Telegram user ID (for authorization - get it from @userinfobot)
TELEGRAM_USER_ID=123456789

# Google Calendar API Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google Refresh Token (obtained after first OAuth flow)
# Run: python -m src.auth_setup to get this token
GOOGLE_REFRESH_TOKEN=

# Calendar ID to use (usually "primary" for your main calendar)
GOOGLE_CALENDAR_ID=primary

# Timezone for calendar events
TIMEZONE=Australia/Sydney
